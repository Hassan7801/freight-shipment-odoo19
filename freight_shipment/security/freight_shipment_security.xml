<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_freight_shipment" model="ir.module.category">
        <field name="name">Freight Shipment</field>
        <field name="sequence">30</field>
    </record>

    <record id="res_groups_privilege_freight_shipment" model="res.groups.privilege">
        <field name="name">Shipments</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_freight_shipment"/>
    </record>

    <record id="group_freight_shipment_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_freight_shipment"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Can create and manage shipment requests and cargo items.</field>
    </record>

    <record id="group_freight_shipment_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_freight_shipment"/>
        <field name="implied_ids" eval="[(4, ref('group_freight_shipment_user'))]"/>
        <field name="comment">Can manage shipment types in addition to shipment requests.</field>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
